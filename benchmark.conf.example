# MySQL Standard vs Advanced Edition — benchmark configuration
# Copy to benchmark.conf and fill in your credentials:
#   cp benchmark.conf.example benchmark.conf

# --- Standard Edition (DigitalOcean Managed MySQL) ---
STANDARD_MYSQL_HOST=your-standard-cluster.db.ondigitalocean.com
STANDARD_MYSQL_PORT=25060
STANDARD_MYSQL_USER=doadmin
STANDARD_MYSQL_PASSWORD=CHANGE_ME
STANDARD_MYSQL_DB=benchmark

# --- Advanced Edition (DigitalOcean Managed MySQL) ---
ADVANCED_MYSQL_HOST=your-advanced-cluster.db.ondigitalocean.com
ADVANCED_MYSQL_PORT=25060
ADVANCED_MYSQL_USER=doadmin
ADVANCED_MYSQL_PASSWORD=CHANGE_ME
ADVANCED_MYSQL_DB=benchmark

# --- TPC-C dataset (identical on both editions for fair comparison) ---
TPCC_TABLES=10
TPCC_SCALE=100
TPCC_FORCE_PK=1
TPCC_TRX_LEVEL=RR

# --- Test matrix ---
# Thread counts (space-separated)
THREADS="8 16 32 64"
# Run durations in seconds: 600=10m, 1200=20m
DURATIONS="600 1200"
WARMUP_SEC=60
PREP_THREADS=16
TPCC_REPORT_INTERVAL=10

# --- Behavior ---
# Editions to run: "standard advanced" or just one
EDITIONS="standard advanced"
# Drop TPC-C tables after all runs (0=keep, 1=cleanup)
CLEANUP_AFTER=0
# Skip prepare if tables already exist (0=always prepare, 1=skip)
SKIP_PREPARE=0

# --- MySQL server settings audit (fair comparison) ---
# Run settings comparison before benchmark (1=yes, 0=skip)
MYSQL_SETTINGS_CHECK=1
# Fail benchmark if Standard and Advanced settings differ (0=warn only, 1=abort)
MYSQL_FAIL_ON_SETTINGS_MISMATCH=0
# Variables to capture from both clusters (space-separated)
# Align these in DigitalOcean cluster settings before benchmarking.
MYSQL_VARS="version version_comment innodb_buffer_pool_size innodb_buffer_pool_instances innodb_log_file_size innodb_flush_log_at_trx_commit innodb_io_capacity innodb_io_capacity_max innodb_read_io_threads innodb_write_io_threads max_connections sql_require_primary_key transaction_isolation binlog_format sync_binlog character_set_server collation_server"
# Optional: document your intended cluster config (informational — set in DO control panel)
# MYSQL_CLUSTER_PLAN="db-s-4vcpu-8gb"
# STANDARD_CLUSTER_SIZE_SLUG=db-s-4vcpu-8gb
# ADVANCED_CLUSTER_SIZE_SLUG=mysql-g-8vcpu-32gb   # shown as "Slug size" in failover HTML report
# MYSQL_NOTES="Buffer pool and CPU/RAM must match between Standard and Advanced clusters"

# --- Failover benchmark ---
# Editions to run: "standard advanced" or one edition
FAILOVER_EDITIONS="standard advanced"

# TPC-C load during failover test
# FAILOVER_THREADS=16
# Timeline (elapsed sec from sysbench start; trigger = warmup + baseline):
# FAILOVER_WARMUP_SEC=0            # optional warmup before baseline
# FAILOVER_BASELINE_SEC=300        # steady load before failover trigger
# FAILOVER_OBSERVE_SEC=300         # keep load running after trigger (harness also sleeps this long)
# FAILOVER_TRIGGER_SECOND=         # optional override; default warmup + baseline (= 300 with defaults above)
# Per scenario wall clock: warmup + baseline + observe (600s with defaults above)
# FAILOVER_REPORT_INTERVAL=1       # 1-second granularity (required for RTO + graphs)
# FAILOVER_MONITOR_INTERVAL=1      # primary/topology poll interval (seconds)
# FAILOVER_MONITOR_WRITE_PROBE=1   # separate write INSERT each poll (HAProxy write routing)
# FAILOVER_GENERATE_GRAPHS=1       # PNG + interactive HTML (HTML needs no extra deps; PNG needs matplotlib)
# FAILOVER_MONITOR_PRIMARY=1       # poll @@hostname, read_only, GR state/role, write probe
# FAILOVER_COLLECT_K8S_EVENTS=1    # kubectl event snapshots (Advanced only)
# FAILOVER_RUN_TPCC_CHECK=0        # 1 = TPC-C check after failover (sets data_loss in failover_kpi.csv)
#
# Dual TPC-C scenarios in one run (mixed read/write, then write-only new_order+payment):
# FAILOVER_SCENARIOS="mixed write_only"   # default; use "mixed" to skip write_only
# FAILOVER_SCENARIO_DELAY_SEC=120         # pause between scenarios (cooldown / cluster settle)
# TPC-C trx_profile is passed to tpcc.lua: mixed = standard TPC-C mix; write_only = 50/50 new_order/payment
#
# Output: results/failover_*/<edition>/<scenario>/failover_kpi.csv (KPIs, phase durations in seconds):
#   mixed/      — standard TPC-C transaction mix (reads + writes)
#   write_only/ — 100% new_order/payment; writes_failed_during_failover KPI populated
# Combined rollup: results/failover_*/failover_kpi.csv and failover_comparison.txt
#   failure_detection_sec   — trigger → first failure signal (err/reconn/outage)
#   primary_election_sec    — failure detected → promotion (write probe / GR PRIMARY / TPS recovery on Advanced)
#   app_recovery_sec        — primary elected → TPS/QPS >= 90% baseline
#   tps_dip_duration_sec    — seconds with TPS < 90% baseline (failure → recovery)
#   peak_latency_failover_ms, transactions_failed_during_failover, data_loss
#
# Sysbench reconnect through GR/failover errors (keep full list):
# FAILOVER_MYSQL_IGNORE_ERRORS=1053,2013,1290,3100,1205,1213,2006,2014,2003,2055,1047,1158,1159,1161,3011
#
# Trigger control (same timeline either way):
# FAILOVER_TRIGGER_ENABLED=1       # 0 = skip all failover actions
# FAILOVER_POD_DELETE=1            # Advanced: 0 = no kubectl pod delete (control run)

# RTO analysis thresholds
# FAILOVER_RECOVERY_THRESHOLD=0.90   # 90% of baseline TPS = recovered
# FAILOVER_RECOVERY_STABLE_SEC=30    # consecutive seconds at threshold
# FAILOVER_OUTAGE_TPS_RATIO=0.05     # TPS below this = outage

# --- Short local smoke test (~4 min) — append to benchmark.conf ---
# FAILOVER_WARMUP_SEC=60
# FAILOVER_BASELINE_SEC=60
# FAILOVER_OBSERVE_SEC=120
# FAILOVER_EDITIONS=advanced
# SKIP_PREPARE=1
# TPCC_TABLES=1
# TPCC_SCALE=10
# FAILOVER_POD_DELETE=0              # step 1: control run (no pod delete)
# FAILOVER_POD_DELETE=1              # step 2: real failover test
# FAILOVER_MYSQL_IGNORE_ERRORS=1053,2013,1290,3100,1205,1213,2006,2014,2003,2055,1047,1158,1159,1161,3011

# --- Standard Edition failover trigger ---
# Method: power_off | install_update | storage_resize | manual
FAILOVER_STANDARD_TRIGGER_METHOD=install_update

# Control panel cluster UUID (for install_update, storage_resize, events)
STANDARD_CLUSTER_UUID=

# Internal dbaas API (power_off primary node only — NOT control panel cluster UUID)
# DO_DBAAS_API_TOKEN=
# STANDARD_PRIMARY_NODE_UUID=
# STANDARD_DBAAS_POWER_URL=https://api.digitalocean.com/v2/dbaas/clusters/{node-uuid}/power

# Public DO API token (install_update, storage_resize, events)
# DIGITALOCEAN_TOKEN=

# For storage_resize fallback only:
# STANDARD_CLUSTER_SIZE_SLUG=db-s-4vcpu-8gb
# STANDARD_CLUSTER_STORAGE_MIB=204800
# STANDARD_CLUSTER_NUM_NODES=3

# --- Advanced Edition failover trigger (kubectl delete primary pod) ---
# Ungraceful kill (default): grace-period=0 --force
FAILOVER_POD_DELETE_FORCE=1
FAILOVER_POD_DELETE_GRACE_SEC=0
# Graceful delete instead: FAILOVER_POD_DELETE_FORCE=0 FAILOVER_POD_DELETE_GRACE_SEC=30
ADVANCED_CLUSTER_UUID=

# Kubeconfig: use one of these (fill in when API details are available)
# ADVANCED_KUBECONFIG_PATH=/path/to/kubeconfig
# ADVANCED_KUBECONFIG_FETCH_URL=https://api.digitalocean.com/v2/dbaas/clusters/{uuid}/kubeconfig
# ADVANCED_KUBECONFIG_FETCH_TOKEN=
# ADVANCED_KUBECONFIG_FETCH_CMD='curl -sS -H "Authorization: Bearer $TOKEN" "https://..." > "$RESULTS_DIR/kubeconfig"'

ADVANCED_K8S_NAMESPACE=
# ADVANCED_K8S_CONTEXT=
# ADVANCED_K8S_PRIMARY_POD_NAME=          # optional if auto-detect works
# ADVANCED_K8S_POD_LABEL_SELECTOR=        # e.g. mysql.percona.com/role=primary
# ADVANCED_K8S_CLUSTER_LABEL=app.kubernetes.io/instance=mysql
# ADVANCED_K8S_PRIMARY_ROLE_LABEL=role=primary

# Reuse TPC-C dataset settings from above; for failover-only runs:
# SKIP_PREPARE=1
# TPCC_TABLES=1
# TPCC_SCALE=50
